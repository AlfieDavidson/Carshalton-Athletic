// ── Scout rating selector ──
function buildSRSelector(currentVal){
  const c=el('d-sr-sel');c.innerHTML='';
  for(const [key,d] of Object.entries(SR_DEFS)){
    const btn=document.createElement('button');
    btn.className='sr-opt'+(currentVal===key?' sel-'+d.cls:'');
    btn.title=d.desc;
    btn.textContent=d.label;
    btn.onclick=()=>{
      const p=players.find(x=>x.id===viewId);if(!p)return;
      p.scoutRating=key;save();render();
      buildSRSelector(key);
    };
    c.appendChild(btn);
  }
  // clear option
  const clr=document.createElement('button');
  clr.className='sr-opt';clr.textContent='—';clr.title='Clear rating';
  clr.onclick=()=>{const p=players.find(x=>x.id===viewId);if(!p)return;p.scoutRating='';save();render();buildSRSelector('');};
  c.appendChild(clr);
}

// ── Action selector ──
function buildActSelector(currentVal){
  const c=el('d-act-sel');c.innerHTML='';
  for(const [key,d] of Object.entries(ACT_DEFS)){
    const btn=document.createElement('button');
    btn.className='act-opt'+(currentVal===key?' sel-'+d.cls:'');
    btn.textContent=d.label;
    btn.onclick=()=>{
      const p=players.find(x=>x.id===viewId);if(!p)return;
      const newVal=p.action===key?'':key;
      p.action=newVal;save();render();buildActSelector(newVal);
    };
    c.appendChild(btn);
  }
}

// ── Star ratings ──
function buildStars(cId,nId,field,val){
  const c=el(cId),n=el(nId);c.innerHTML='';
  for(let i=1;i<=5;i++){
    const b=document.createElement('button');b.className='sbtn'+(i<=val?' lit':'');b.textContent='★';
    const v=i;
    b.onclick=()=>{const p=players.find(x=>x.id===viewId);if(!p)return;p[field]=v;save();buildStars(cId,nId,field,v);n.textContent=v+'/5';render();};
    b.onmouseenter=()=>{c.querySelectorAll('.sbtn').forEach((s,j)=>s.style.color=j<v?'var(--gold)':'#ddd');};
    b.onmouseleave=()=>{const cur=(players.find(x=>x.id===viewId)||{})[field]||0;c.querySelectorAll('.sbtn').forEach((s,j)=>s.style.color=j<cur?'var(--gold)':'#ddd');};
    c.appendChild(b);
  }
  n.textContent=val>0?val+'/5':'—';
}

function openDetail(id){
  const p=players.find(x=>x.id===id);if(!p)return;
  viewId=id;
  const stepLabel=STEP_META[String(p.step||p.tier||'')]?.label||String(p.step||'');
  el('d-name').textContent=p.name;
  el('d-sub').textContent=(p.position||'')+(p.currentClub?' · '+p.currentClub:'')+(p.age?' · '+p.age+' yrs':'');
  el('d-name2').textContent=p.name;
  el('d-age').textContent=p.age?p.age+' years old':'—';
  el('d-pos').textContent=p.position||'—';
  el('d-club').textContent=p.currentClub||'—';
  el('d-tier').innerHTML=stepBadge(p.step||p.tier||'')+'<span style="font-size:12px;color:var(--ink-mid);margin-left:8px">'+stepLabel+'</span>';
  const ci=CLUB_REGISTRY[p.currentClub];
  el('d-travel').textContent=ci?'~'+ci.travel+' mins drive':'—';
  el('d-date').textContent=p.date?new Date(p.date).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'}):'—';
  el('d-status-sel').value=p.status||'Not Watched';
  buildActSelector(p.action||'');
  buildSRSelector(p.scoutRating||'');
  buildStars('sr-inposs','srn-inposs','ratingInPoss',p.ratingInPoss||0);
  buildStars('sr-outposs','srn-outposs','ratingOutPoss',p.ratingOutPoss||0);
  el('aiOut').textContent='Click Generate to produce AI scouting notes.';
  el('aiOut').className='aiout';el('aiUse').style.display='none';
  el('d-notes-ta').value=p.notes||'';el('save-ind').textContent='';
  el('delbtn').onclick=()=>delP(id);
  showTab('info');openModal('detailModal');
}

function quickUpdate(field,val){
  const p=players.find(x=>x.id===viewId);if(!p)return;
  p[field]=val;save();render();showToast(field+' updated.','success');
}
function autoSave(){
  clearTimeout(saveTimer);
  saveTimer=setTimeout(()=>{
    const p=players.find(x=>x.id===viewId);if(!p)return;
    p.notes=el('d-notes-ta').value;save();render();
    el('save-ind').textContent='Saved ✓';setTimeout(()=>el('save-ind').textContent='',2000);
  },500);
}

async function genAI(){
  const p=players.find(x=>x.id===viewId);if(!p)return;
  const btn=el('aiBtn');btn.disabled=true;btn.textContent='Generating…';
  const out=el('aiOut');out.className='aiout loading';out.textContent='Generating scouting notes…';
  el('aiUse').style.display='none';
  const srDesc=SR_DEFS[p.scoutRating]?`${p.scoutRating} (${SR_DEFS[p.scoutRating].desc})`:'Not rated';
  const prompt=`You are a football scout for Carshalton Athletic FC in the Isthmian Premier Division (Step 3).\nWrite 4-6 sentences of professional scouting notes for:\n- Name: ${p.name}\n- Position: ${p.position||'Unknown'}\n- Club: ${p.currentClub||'Unknown'}\n- Level: ${STEP_META[String(p.step||p.tier||'')]?.label||''}\n- Scout Rating: ${srDesc}\n- In Possession: ${(p.ratingInPoss||0)>0?p.ratingInPoss+'/5':'not rated'}\n- Out of Possession: ${(p.ratingOutPoss||0)>0?p.ratingOutPoss+'/5':'not rated'}\nBe specific, realistic and relevant to Step 3. Plain text only.`;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:prompt}]})});
    const d=await r.json();
    aiText=d.content?.map(b=>b.type==='text'?b.text:'').join('')||'';
    if(!aiText)throw new Error();
    out.className='aiout';out.textContent=aiText;el('aiUse').style.display='block';
  }catch{out.className='aiout';out.textContent='Could not generate. Try again or write manually.';}
  btn.disabled=false;btn.textContent='Generate';
}
function applyAI(){
  const ta=el('d-notes-ta');ta.value=ta.value.trim()?(ta.value.trim()+'\n\n'+aiText):aiText;
  el('aiUse').style.display='none';el('aiOut').textContent='Notes added — see Notes tab.';
  showTab('notes');autoSave();showToast('AI notes added.','success');
}
function delP(id){
  if(!confirm('Delete this player?'))return;
  players=players.filter(p=>p.id!==id);save();render();closeModal('detailModal');showToast('Player removed.');
}
function openAddModal(){
  editId=null;el('modalTitle').textContent='Add Player';
  ['f-name','f-age'].forEach(id=>el(id).value='');
  el('f-position').value='';el('f-status').value='Not Watched';
  el('f-club').value='';el('f-step').value='1';
  el('f-scoutRating').value='';
  el('f-date').value=new Date().toISOString().split('T')[0];
  openModal('addModal');
}
function openEditDirect(id){
  const p=players.find(x=>x.id===id);if(!p)return;editId=id;
  el('modalTitle').textContent='Edit Player';
  el('f-name').value=p.name||'';el('f-age').value=p.age||'';
  el('f-position').value=p.position||'';el('f-status').value=p.status||'Not Watched';
  el('f-club').value=p.currentClub||'';el('f-step').value=String(p.step||p.tier||'1');
  el('f-scoutRating').value=p.scoutRating||'';
