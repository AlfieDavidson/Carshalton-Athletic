<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Carshalton Athletic — Recruitment Database</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#C0272D;--red-light:#f7e8e8;--red-dark:#8C1A1E;
  --gold:#E8C547;
  --ink:#1A1A1A;--ink-mid:#4A4A4A;--ink-soft:#7A7A7A;
  --rule:#E2E2E2;--rule-light:#F0F0F0;
  --surface:#FAFAF8;--white:#FFFFFF;
  --s-nw:#7A7A7A;--s-nw-bg:#F0F0F0;
  --s-w:#185FA5;--s-w-bg:#E6F1FB;
  /* Scout ratings */
  --astar:#1a7a2e;--astar-bg:#d4f0db;
  --a:#2d9e46;--a-bg:#e2f7e7;
  --b:#1a6fa8;--b-bg:#ddeef8;
  --c:#b07d10;--c-bg:#fdf3d7;
  --d:#c05c10;--d-bg:#fdebd7;
  --e:#a0282d;--e-bg:#fde8e8;
  /* Actions */
  --act-sl:#185FA5;--act-sl-bg:#E6F1FB;
  --act-ll:#534AB7;--act-ll-bg:#EEEDFE;
  --act-mo:#3B6D11;--act-mo-bg:#EAF3DE;
  --act-nd:#C0272D;--act-nd-bg:#f7e8e8;
  --act-nfa:#7A7A7A;--act-nfa-bg:#F0F0F0;
}
body{font-family:'DM Mono',monospace;background:var(--surface);color:var(--ink);min-height:100vh}
.header{background:#fff;padding:10px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--red);box-shadow:0 1px 4px rgba(0,0,0,.06)}
.hbrand{display:flex;align-items:center;gap:12px}
.hbadge{width:54px;height:54px;object-fit:contain;flex-shrink:0}
.htitle{font-family:'Fraunces',serif;font-size:16px;font-weight:500;color:var(--ink);line-height:1.2}
.hsub{font-size:10px;color:var(--ink-soft);letter-spacing:.08em;text-transform:uppercase;margin-top:1px}
.header-btns{display:flex;gap:8px;align-items:center}
.hbtn{background:var(--red);color:white;border:none;padding:8px 14px;font-family:'DM Mono',monospace;font-size:11px;font-weight:500;cursor:pointer;border-radius:4px;transition:background .15s}
.hbtn:hover{background:var(--red-dark)}
.hbtn.ghost{background:transparent;border:1px solid var(--rule);color:var(--ink-mid)}
.hbtn.ghost:hover{border-color:var(--ink);color:var(--ink)}
.server-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:#ccc;margin-right:5px;vertical-align:middle;transition:background .3s}
.server-dot.online{background:#3B6D11}
.server-dot.offline{background:#C0272D}
.server-status{font-size:10px;color:var(--ink-soft)}
.layout{display:grid;grid-template-columns:264px 1fr;min-height:calc(100vh - 77px)}
.sidebar{background:var(--white);border-right:1px solid var(--rule);padding:16px 14px;display:flex;flex-direction:column;gap:16px;overflow-y:auto}
.slabel{font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:5px}
.sbox{width:100%;padding:7px 10px;font-family:'DM Mono',monospace;font-size:12px;border:1px solid var(--rule);border-radius:4px;background:var(--surface);color:var(--ink);outline:none}
.sbox:focus{border-color:var(--red)}
.fg{display:flex;flex-direction:column;gap:2px}
.fi{display:flex;align-items:center;justify-content:space-between;padding:5px 8px;border-radius:4px;cursor:pointer;font-size:12px;color:var(--ink-mid);transition:background .1s;user-select:none}
.fi:hover{background:var(--rule-light)}
.fi.active{background:var(--red-light);color:var(--red-dark);font-weight:500}
.fi.active .fcnt{background:rgba(192,39,45,.15);color:var(--red)}
.fdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-right:7px}
.flabel{flex:1}
.fcnt{font-size:10px;background:var(--rule-light);padding:1px 6px;border-radius:10px;color:var(--ink-soft)}
/* Expandable position groups */
.pos-group{display:flex;flex-direction:column;gap:0}
.pos-parent{display:flex;align-items:center;justify-content:space-between;padding:5px 8px;border-radius:4px;cursor:pointer;font-size:12px;color:var(--ink-mid);transition:background .1s;user-select:none}
.pos-parent:hover{background:var(--rule-light)}
.pos-parent.active{background:var(--red-light);color:var(--red-dark);font-weight:500}
.pos-parent.active .fcnt{background:rgba(192,39,45,.15);color:var(--red)}
.pos-chevron{font-size:9px;color:var(--ink-soft);transition:transform .2s;margin-left:4px}
.pos-children{display:none;flex-direction:column;gap:0;padding-left:14px}
.pos-children.open{display:flex}
.pos-child{display:flex;align-items:center;justify-content:space-between;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:11px;color:var(--ink-soft);transition:background .1s;user-select:none}
.pos-child:hover{background:var(--rule-light)}
.pos-child.active{background:var(--red-light);color:var(--red-dark);font-weight:500}
.pos-child.active .fcnt{background:rgba(192,39,45,.15);color:var(--red)}
/* Scout rating filter */
.sr-row{display:flex;align-items:center;justify-content:space-between;padding:5px 8px;border-radius:4px;cursor:pointer;transition:background .1s;user-select:none;gap:6px}
.sr-row:hover{background:var(--rule-light)}
.sr-row.active{background:var(--red-light)}
.sr-row.active .fcnt{background:rgba(192,39,45,.15);color:var(--red)}
.sr-badge{font-size:11px;font-weight:700;width:26px;text-align:center;flex-shrink:0;border-radius:3px;padding:1px 4px}
.sr-desc{font-size:11px;color:var(--ink-soft);flex:1}
.pipe{display:flex;flex-direction:column;gap:5px}
.prow{display:flex;align-items:center;gap:7px}
.pbar-w{flex:1;height:5px;background:var(--rule-light);border-radius:3px;overflow:hidden}
.pbar{height:100%;border-radius:3px;transition:width .4s ease}
.plbl{font-size:10px;color:var(--ink-soft);width:80px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pnum{font-size:10px;color:var(--ink-soft);width:18px;text-align:right}
.main{padding:20px 24px;overflow:auto}
.sumrow{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap}
.scard{background:var(--white);border:1px solid var(--rule);border-radius:6px;padding:12px 16px;min-width:82px;flex:1}
.snum{font-family:'Fraunces',serif;font-size:22px;font-weight:500;color:var(--ink);line-height:1}
.slbl2{font-size:10px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.08em;margin-top:3px}
.scard.hl{border-color:var(--red);background:var(--red-light)}
.scard.hl .snum{color:var(--red)}
.twrap{background:var(--white);border:1px solid var(--rule);border-radius:6px;overflow:hidden}
.thead2{padding:10px 14px;border-bottom:1px solid var(--rule);display:flex;align-items:center;justify-content:space-between;background:var(--surface)}
.ttitle{font-family:'Fraunces',serif;font-size:14px;font-weight:500}
.tmeta{font-size:11px;color:var(--ink-soft)}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{padding:7px 10px;text-align:left;font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);background:var(--surface);border-bottom:1px solid var(--rule);white-space:nowrap;cursor:pointer;user-select:none}
thead th:hover{color:var(--ink)}
tbody tr{border-bottom:1px solid var(--rule-light);transition:background .1s;cursor:pointer}
tbody tr:hover{background:var(--surface)}
tbody tr:last-child{border-bottom:none}
td{padding:7px 10px;vertical-align:middle}
.pname{font-weight:500;color:var(--ink);font-size:13px}
.page{color:var(--ink-soft);font-size:11px}
.pos-pill{font-size:10px;font-weight:500;padding:2px 6px;border-radius:3px;background:var(--rule-light);color:var(--ink-mid)}
.sb{font-size:10px;font-weight:500;padding:2px 7px;border-radius:10px;white-space:nowrap}
/* Scout rating badge */
.sr-b{font-size:11px;font-weight:700;padding:2px 7px;border-radius:4px;display:inline-block}
.sr-b.Astar{background:var(--astar-bg);color:var(--astar)}
.sr-b.A{background:var(--a-bg);color:var(--a)}
.sr-b.B{background:var(--b-bg);color:var(--b)}
.sr-b.C{background:var(--c-bg);color:var(--c)}
.sr-b.D{background:var(--d-bg);color:var(--d)}
.sr-b.E{background:var(--e-bg);color:var(--e)}
/* Action badge */
.act-b{font-size:10px;font-weight:500;padding:2px 7px;border-radius:10px;white-space:nowrap}
.act-b.Shortlist{background:var(--act-sl-bg);color:var(--act-sl)}
.act-b.Longlist{background:var(--act-ll-bg);color:var(--act-ll)}
.act-b.Monitor{background:var(--act-mo-bg);color:var(--act-mo)}
.act-b.NoDeal{background:var(--act-nd-bg);color:var(--act-nd)}
.act-b.NFA{background:var(--act-nfa-bg);color:var(--act-nfa)}
.abtn{background:none;border:1px solid var(--rule);border-radius:3px;padding:3px 7px;font-family:'DM Mono',monospace;font-size:10px;cursor:pointer;color:var(--ink-mid);transition:all .15s}
.abtn:hover{border-color:var(--red);color:var(--red)}
.nores{padding:32px;text-align:center;color:var(--ink-soft);font-size:13px}
/* Tier badges */
.tnl{background:#EEEDFE;color:#3C3489}
.tnls{background:#FAECE7;color:#712B13}
.tist{background:#EAF3DE;color:#27500A}
.ts4{background:#FBF4D6;color:#7A5C00}
.tu21{background:#E6F1FB;color:#0C447C}
.tcat2{background:#fce8f7;color:#7a1068}
.tcat3{background:#fff0e0;color:#8a4500}
/* MODALS */
.mo{position:fixed;inset:0;background:rgba(26,26,26,.55);z-index:1000;display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .2s}
.mo.open{opacity:1;pointer-events:all}
.md{background:var(--white);border-radius:8px;width:100%;max-width:580px;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.22);transform:translateY(10px);transition:transform .2s}
.md.wide{max-width:720px}
.mo.open .md{transform:translateY(0)}
.mhd{padding:18px 22px 14px;border-bottom:1px solid var(--rule);display:flex;align-items:flex-start;justify-content:space-between}
.mtitle{font-family:'Fraunces',serif;font-size:18px;font-weight:500}
.msub{font-size:11px;color:var(--ink-soft);margin-top:3px}
.mcls{background:none;border:none;font-size:22px;cursor:pointer;color:var(--ink-soft);padding:0;line-height:1}
.sect-tabs{display:flex;border-bottom:1px solid var(--rule);padding:0 22px;background:var(--surface)}
.stab{padding:10px 14px;font-size:12px;cursor:pointer;color:var(--ink-soft);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;font-weight:500}
.stab:hover{color:var(--ink)}
.stab.active{color:var(--red);border-bottom-color:var(--red)}
.sect-panel{display:none;padding:20px 22px}
.sect-panel.active{display:block}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.info-field label{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);display:block;margin-bottom:3px}
.info-val{font-size:13px;color:var(--ink)}
.status-sel{font-family:'DM Mono',monospace;font-size:12px;padding:6px 8px;border:1px solid var(--rule);border-radius:4px;background:var(--surface);color:var(--ink);outline:none;cursor:pointer;width:100%}
.status-sel:focus{border-color:var(--red)}
/* Scout rating selector in detail */
.sr-selector{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.sr-opt{border:1.5px solid var(--rule);border-radius:5px;padding:5px 10px;cursor:pointer;font-size:12px;font-weight:700;transition:all .15s;background:var(--surface)}
.sr-opt:hover{border-color:var(--ink-mid)}
.sr-opt.sel-Astar{background:var(--astar-bg);color:var(--astar);border-color:var(--astar)}
.sr-opt.sel-A{background:var(--a-bg);color:var(--a);border-color:var(--a)}
.sr-opt.sel-B{background:var(--b-bg);color:var(--b);border-color:var(--b)}
.sr-opt.sel-C{background:var(--c-bg);color:var(--c);border-color:var(--c)}
.sr-opt.sel-D{background:var(--d-bg);color:var(--d);border-color:var(--d)}
.sr-opt.sel-E{background:var(--e-bg);color:var(--e);border-color:var(--e)}
/* Action selector */
.act-selector{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.act-opt{border:1.5px solid var(--rule);border-radius:10px;padding:4px 10px;cursor:pointer;font-size:11px;font-weight:500;transition:all .15s;background:var(--surface);color:var(--ink-mid)}
.act-opt:hover{border-color:var(--ink-mid)}
.act-opt.sel-Shortlist{background:var(--act-sl-bg);color:var(--act-sl);border-color:var(--act-sl)}
.act-opt.sel-Longlist{background:var(--act-ll-bg);color:var(--act-ll);border-color:var(--act-ll)}
.act-opt.sel-Monitor{background:var(--act-mo-bg);color:var(--act-mo);border-color:var(--act-mo)}
.act-opt.sel-NoDeal{background:var(--act-nd-bg);color:var(--act-nd);border-color:var(--act-nd)}
.act-opt.sel-NFA{background:var(--act-nfa-bg);color:var(--act-nfa);border-color:var(--act-nfa)}
/* Report tab */
.report-block{margin-bottom:22px}
.report-block-title{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--rule-light)}
.rrow{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.rlabel{font-size:12px;color:var(--ink-mid);width:155px;flex-shrink:0}
.star-display{display:flex;gap:2px}
.sbtn{background:none;border:none;cursor:pointer;font-size:22px;color:#ddd;padding:0;transition:color .1s;line-height:1}
.sbtn.lit{color:var(--gold)}
.rnum{font-size:11px;color:var(--ink-soft);width:32px}
.notes-ta{width:100%;min-height:130px;font-family:'DM Mono',monospace;font-size:12px;padding:10px 12px;border:1px solid var(--rule);border-radius:4px;background:var(--surface);color:var(--ink);outline:none;resize:vertical;line-height:1.8}
.notes-ta:focus{border-color:var(--red)}
.aipanel{background:var(--ink);border-radius:6px;padding:12px 14px;margin-top:2px}
.aihdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.ailbl{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--gold)}
.aibtn{background:var(--red);color:white;border:none;padding:5px 12px;font-family:'DM Mono',monospace;font-size:10px;border-radius:3px;cursor:pointer}
.aibtn:disabled{opacity:.5;cursor:not-allowed}
.aiout{font-size:11px;color:#ccc;line-height:1.7;min-height:40px;white-space:pre-wrap}
.aiout.loading{color:#666;font-style:italic}
.aiuse{margin-top:8px;background:none;border:1px solid #444;color:#aaa;padding:4px 10px;font-family:'DM Mono',monospace;font-size:10px;border-radius:3px;cursor:pointer;display:none}
.aiuse:hover{border-color:var(--gold);color:var(--gold)}
/* Add/Edit */
.mbdy{padding:18px 22px;display:flex;flex-direction:column;gap:12px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fgrp{display:flex;flex-direction:column;gap:4px}
.fgrp.full{grid-column:1/-1}
label{font-size:10px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft)}
input,select,textarea{font-family:'DM Mono',monospace;font-size:12px;padding:7px 9px;border:1px solid var(--rule);border-radius:4px;background:var(--surface);color:var(--ink);outline:none;transition:border-color .15s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--red)}
textarea{resize:vertical;min-height:70px}
.mft{padding:14px 22px;border-top:1px solid var(--rule);display:flex;gap:8px;justify-content:flex-end;align-items:center}
.bpri{background:var(--red);color:white;border:none;padding:8px 18px;font-family:'DM Mono',monospace;font-size:12px;font-weight:500;border-radius:4px;cursor:pointer}
.bpri:hover{background:var(--red-dark)}
.bsec{background:none;color:var(--ink-mid);border:1px solid var(--rule);padding:8px 14px;font-family:'DM Mono',monospace;font-size:12px;border-radius:4px;cursor:pointer}
.bdel{background:none;border:1px solid #e0c0c0;color:#c05050;padding:8px 14px;font-family:'DM Mono',monospace;font-size:12px;border-radius:4px;cursor:pointer;margin-right:auto}
.bdel:hover{background:#fff0f0;border-color:var(--red);color:var(--red)}
/* Sync */
.sync-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;max-height:52vh;overflow-y:auto;padding:2px}
.sync-club-card{border:1px solid var(--rule);border-radius:6px;padding:10px 12px;display:flex;flex-direction:column;gap:5px;background:var(--surface)}
.sync-club-name{font-size:12px;font-weight:500;color:var(--ink)}
.sync-club-meta{font-size:10px;color:var(--ink-soft)}
.sync-st{font-size:10px;padding:2px 6px;border-radius:3px;font-weight:500;width:fit-content}
.sync-st.idle{background:var(--rule-light);color:var(--ink-soft)}
.sync-st.loading{background:#E6F1FB;color:#185FA5}
.sync-st.done{background:#EAF3DE;color:#3B6D11}
.sync-st.error{background:#f7e8e8;color:#C0272D}
.sync-btn{background:none;border:1px solid var(--rule);border-radius:3px;padding:3px 8px;font-family:'DM Mono',monospace;font-size:10px;cursor:pointer;color:var(--ink-mid);align-self:flex-start}
.sync-btn:hover{border-color:#185FA5;color:#185FA5}
.sync-btn:disabled{opacity:.4;cursor:not-allowed}
.sync-sec{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);padding:6px 2px 2px;grid-column:1/-1;border-top:1px solid var(--rule-light);margin-top:2px}
.sync-sec:first-child{border-top:none;margin-top:0}
.server-notice{background:#f7e8e8;border:1px solid #e0c0c0;border-radius:6px;padding:12px;font-size:12px;color:var(--red-dark);line-height:1.7;margin-bottom:10px}
.server-notice strong{display:block;margin-bottom:3px}
.toast{position:fixed;bottom:20px;right:20px;background:var(--ink);color:white;padding:9px 16px;border-radius:6px;font-size:12px;z-index:2000;transform:translateY(80px);opacity:0;transition:all .3s;border-left:3px solid var(--red)}
.toast.show{transform:translateY(0);opacity:1}
.toast.success{border-left-color:#3B6D11}
</style>
</head>
<body>
<header class="header">
  <div class="hbrand">
    <img src="data:image/png;base64," class="hbadge" alt="CAFC">
    <div><div class="htitle">Carshalton Athletic FC</div><div class="hsub">Recruitment Database</div></div>
  </div>
  <div class="header-btns">
    <span class="server-status"><span class="server-dot" id="serverDot"></span><span id="serverLabel">Checking…</span></span>
    <button class="hbtn ghost" onclick="openSyncModal()">⟳ Sync Transfermarkt</button>
    <button class="hbtn" onclick="openAddModal()">+ Add Player</button>
  </div>
</header>

<div class="layout">
<aside class="sidebar">
  <div><div class="slabel">Search</div><input type="text" class="sbox" id="gs" placeholder="Name, club, position…"></div>

  <!-- STATUS -->
  <div>
    <div class="slabel">Status <span style="font-weight:400;opacity:.6;font-size:8px">· multi-select</span></div>
    <div class="fg" id="sfil">
      <div class="fi active" data-val="all" onclick="setF('sf','all',this)"><span class="fdot" style="background:#ccc"></span><span class="flabel">All Players</span><span class="fcnt" id="fc-all">0</span></div>
      <div class="fi" data-val="Not Watched" onclick="setF('sf','Not Watched',this)"><span class="fdot" style="background:var(--s-nw)"></span><span class="flabel">Not Watched</span><span class="fcnt" id="fc-nw">0</span></div>
      <div class="fi" data-val="Watched" onclick="setF('sf','Watched',this)"><span class="fdot" style="background:var(--s-w)"></span><span class="flabel">Watched</span><span class="fcnt" id="fc-w">0</span></div>
    </div>
  </div>

  <!-- ACTION -->
  <div>
    <div class="slabel">Action <span style="font-weight:400;opacity:.6;font-size:8px">· multi-select</span></div>
    <div class="fg" id="acfil">
      <div class="fi active" data-val="all" onclick="setF('af','all',this)"><span class="flabel">All Actions</span><span class="fcnt" id="fa-all">0</span></div>
      <div class="fi" data-val="Shortlist" onclick="setF('af','Shortlist',this)"><span class="fdot" style="background:var(--act-sl)"></span><span class="flabel">Shortlist</span><span class="fcnt" id="fa-Shortlist">0</span></div>
      <div class="fi" data-val="Longlist" onclick="setF('af','Longlist',this)"><span class="fdot" style="background:var(--act-ll)"></span><span class="flabel">Longlist</span><span class="fcnt" id="fa-Longlist">0</span></div>
      <div class="fi" data-val="Monitor" onclick="setF('af','Monitor',this)"><span class="fdot" style="background:var(--act-mo)"></span><span class="flabel">Monitor</span><span class="fcnt" id="fa-Monitor">0</span></div>
