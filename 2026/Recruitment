    }
    if(ratingF.size>0&&!ratingF.has(p.scoutRating||''))return false;
    if(sq){const t=sq.toLowerCase();if(!p.name.toLowerCase().includes(t)&&!(p.currentClub||'').toLowerCase().includes(t)&&!(p.position||'').toLowerCase().includes(t))return false;}
    return true;
  }).sort((a,b)=>{
    let va=a[sc]??'',vb=b[sc]??'';
    if(va<vb)return sd==='asc'?-1:1;
    if(va>vb)return sd==='asc'?1:-1;
    return 0;
  });
}

function srBadge(r){
  if(!r)return '';
  const d=SR_DEFS[r];if(!d)return '';
  return `<span class="sr-b ${d.cls}">${d.label}</span>`;
}
function actBadge(a){
  if(!a)return '';
  const d=ACT_DEFS[a];if(!d)return '';
  return `<span class="act-b ${d.cls}">${d.label}</span>`;
}
function stepBadge(s){
  const m=STEP_META[String(s)]||{label:String(s),badge:''};
  return `<span class="sb ${m.badge}" style="font-size:10px">${m.label}</span>`;
}
function sbadge(s){const st=SS[s]||SS['Not Watched'];return `<span class="sb" style="background:${st.bg};color:${st.c}">${s}</span>`;}
function el(id){return document.getElementById(id);}
function set(id,v){const e=el(id);if(e)e.textContent=v;}

function render(){
  const f=filtered(),t=players.length;
  const nw=players.filter(p=>p.status==='Not Watched').length;
  const w=players.filter(p=>p.status==='Watched').length;
  const shortlist=players.filter(p=>p.action==='Shortlist').length;
  const rated=players.filter(p=>p.scoutRating==='A*'||p.scoutRating==='A').length;

  el('sumrow').innerHTML=
    `<div class="scard hl"><div class="snum">${t}</div><div class="slbl2">Total Players</div></div>`+
    `<div class="scard"><div class="snum">${players.filter(p=>String(p.step||p.tier||'')=='1').length}</div><div class="slbl2">Step 1 · NL</div></div>`+
    `<div class="scard"><div class="snum">${players.filter(p=>String(p.step||p.tier||'')=='2').length}</div><div class="slbl2">Step 2 · NLS</div></div>`+
    `<div class="scard"><div class="snum">${shortlist}</div><div class="slbl2">Shortlisted</div></div>`+
    `<div class="scard"><div class="snum">${w}</div><div class="slbl2">Watched</div></div>`+
    `<div class="scard"><div class="snum">${rated}</div><div class="slbl2">Rated A/A*</div></div>`;

  // status
  set('fc-all',t);set('fc-nw',nw);set('fc-w',w);
  // action
  set('fa-all',t);
  ['Shortlist','Longlist','Monitor','NoDeal','NFA'].forEach(a=>set('fa-'+a,players.filter(p=>(p.action||'')==a).length));
  // step
  set('fst-all',t);
  ['1','2','3','4','U21','Cat2','Cat3'].forEach(s=>set('fst-'+s,players.filter(p=>String(p.step||p.tier||'')==s).length));
  // positions
  set('fp-all',t);
  ['GK','DEF','MID','FWD'].forEach(g=>set('fp-'+g,players.filter(p=>PG[p.position]===g||p.position===g).length));
  ['GK','CB','RB','LB','DM','CM','AM','RW','LW','CF','ST'].forEach(p=>set('fpc-'+p,players.filter(x=>x.position===p).length));
  // ratings
  set('fr-all',t);
  Object.keys(SR_DEFS).forEach(r=>set('fr-'+r.replace('*','star'),players.filter(p=>(p.scoutRating||'')==r).length));
  set('fr-none',players.filter(p=>!p.scoutRating).length);

  // pipeline
  const mx=Math.max(1,...['Shortlist','Longlist','Monitor'].map(a=>players.filter(p=>p.action===a).length));
  const pipeItems=[
    {label:'Shortlist',val:players.filter(p=>p.action==='Shortlist').length,color:'var(--act-sl)'},
    {label:'Longlist', val:players.filter(p=>p.action==='Longlist').length, color:'var(--act-ll)'},
    {label:'Monitor',  val:players.filter(p=>p.action==='Monitor').length,  color:'var(--act-mo)'},
    {label:'Watched',  val:w,                                                color:'var(--s-w)'},
  ];
  el('pvis').innerHTML=pipeItems.map(i=>`<div class="prow"><div class="plbl">${i.label}</div><div class="pbar-w"><div class="pbar" style="width:${Math.round((i.val/Math.max(1,t))*100)}%;background:${i.color}"></div></div><div class="pnum">${i.val}</div></div>`).join('');

  set('tcnt',f.length+' player'+(f.length!==1?'s':''));
  const tbody=el('tbody');
  if(!f.length){tbody.innerHTML='';el('nores').style.display='block';return;}
  el('nores').style.display='none';
  tbody.innerHTML=f.map(p=>`<tr onclick="openDetail('${p.id}')">
    <td><div class="pname">${p.name}</div>${p.age?`<div class="page">${p.age} yrs</div>`:''}</td>
    <td><span class="pos-pill">${p.position||'—'}</span></td>
    <td style="font-size:12px">${p.currentClub||'—'}</td>
    <td>${stepBadge(p.step||p.tier||'')}</td>
    <td>${srBadge(p.scoutRating)||'<span style="color:var(--ink-soft);font-size:11px">—</span>'}</td>
    <td>${actBadge(p.action)||'<span style="color:var(--ink-soft);font-size:11px">—</span>'}</td>
    <td>${sbadge(p.status)}</td>
    <td><button class="abtn" onclick="event.stopPropagation();openEditDirect('${p.id}')">Edit</button></td>
  </tr>`).join('');
}

function sortBy(col){if(sc===col)sd=sd==='asc'?'desc':'asc';else{sc=col;sd='asc';}render();}

// Multi-select filter toggle
// val='all' clears the set; otherwise toggles the value in/out
function setF(which,val,elem){
  const sets={sf,af,stf,ratingF};
  const containers={sf:'sfil',af:'acfil',stf:'stfil',ratingF:'srfil'};
  const set=sets[which];
  if(val==='all'){
    set.clear();
  } else {
    if(set.has(val)) set.delete(val);
    else set.add(val);
  }
  // Update active states
  const cont=containers[which];
  if(cont){
    // "All" row is active only when set is empty
    document.querySelectorAll('#'+cont+' .fi,#'+cont+' .sr-row').forEach(e=>{
      const eVal=e.dataset.val;
      if(eVal===undefined)return;
      if(eVal==='all'){
        e.classList.toggle('active', set.size===0);
      } else {
        e.classList.toggle('active', set.has(eVal));
      }
    });
  }
  render();
}

