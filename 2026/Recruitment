}
function openEditFromDetail(){closeModal('detailModal');openEditDirect(viewId);}
function savePlayer(){
  const name=el('f-name').value.trim(),pos=el('f-position').value;
  if(!name||!pos){showToast('Please fill Name and Position.');return;}
  if(editId){
    const p=players.find(x=>x.id===editId);if(!p)return;
    p.name=name;p.age=parseInt(el('f-age').value)||null;p.position=pos;
    p.status=el('f-status').value;p.currentClub=el('f-club').value.trim();
    p.step=el('f-step').value;p.scoutRating=el('f-scoutRating').value;
    p.date=el('f-date').value||p.date;
  }else{
    players.unshift({id:uid(),name,age:parseInt(el('f-age').value)||null,position:pos,
      status:el('f-status').value,currentClub:el('f-club').value.trim(),
      step:el('f-step').value,scoutRating:el('f-scoutRating').value,
      action:'',ratingInPoss:0,ratingOutPoss:0,notes:'',
      date:el('f-date').value||new Date().toISOString().split('T')[0]});
  }
  save();render();closeModal('addModal');showToast(editId?'Player updated.':'Player added.','success');editId=null;
}

// ── Server + Sync ──
async function checkServer(){
  try{
    const r=await fetch(SERVER+'/health',{signal:AbortSignal.timeout(2000)});
    const d=await r.json();
    serverOnline=true;el('serverDot').className='server-dot online';
    el('serverLabel').textContent=`Server online · ${d.clubs} clubs`;
  }catch{
    serverOnline=false;el('serverDot').className='server-dot offline';
    el('serverLabel').textContent='Server offline';
  }
}
function openSyncModal(){
  buildSyncGrid();
  el('serverNotice').style.display=serverOnline?'none':'block';
  openModal('syncModal');
}
function buildSyncGrid(){
  const steps=['1','2','3','U21'];
  const stepNames={'1':'Step 1 · National League','2':'Step 2 · NL South','3':'Step 3 · Isthmian Premier','U21':'U21 · Premier League 2'};
  let html='<div class="sync-grid">';
  for(const step of steps){
    const clubs=Object.entries(CLUB_REGISTRY).filter(([,v])=>String(v.step)===step).sort((a,b)=>a[1].travel-b[1].travel);
    if(!clubs.length)continue;
    html+=`<div class="sync-sec">${stepNames[step]} — ${clubs.length} clubs</div>`;
    for(const [name,info] of clubs){
      const sid='sc-'+name.replace(/[^a-z0-9]/gi,'_');
      html+=`<div class="sync-club-card"><div class="sync-club-name">${name}</div><div class="sync-club-meta">~${info.travel} mins</div><div class="sync-st idle" id="st-${sid}">Not synced</div><button class="sync-btn" id="btn-${sid}" onclick="syncClub('${name}','${sid}')">Sync squad</button></div>`;
    }
  }
  html+='</div>';el('syncGrid').innerHTML=html;
}
async function syncClub(clubName,sid){
  if(!serverOnline){showToast('Server offline. Run server.py first.');return;}
  const stEl=el('st-'+sid),btnEl=el('btn-'+sid);
  stEl.className='sync-st loading';stEl.textContent='Fetching…';btnEl.disabled=true;
  try{
    const r=await fetch(`${SERVER}/squad/${encodeURIComponent(clubName)}`);
    if(!r.ok)throw new Error(await r.text());
    const data=await r.json();
    const added=mergeSquad(clubName,data);
    stEl.className='sync-st done';stEl.textContent=`✓ ${data.playerCount} players · ${added} new`;
    render();showToast(`${clubName}: ${added} new players added.`,'success');
  }catch(e){stEl.className='sync-st error';stEl.textContent='Error: '+String(e).slice(0,35);}
  btnEl.disabled=false;
}
async function syncAllByStep(step){
  if(!serverOnline){showToast('Server offline. Run server.py first.');return;}
  const clubs=Object.entries(CLUB_REGISTRY).filter(([,v])=>String(v.step)===step);
  showToast(`Syncing ${clubs.length} clubs…`);let total=0;
  for(const [name] of clubs){
    const sid='sc-'+name.replace(/[^a-z0-9]/gi,'_');
    try{
      const r=await fetch(`${SERVER}/squad/${encodeURIComponent(name)}`);
      if(!r.ok)continue;
      const data=await r.json();total+=mergeSquad(name,data);
      const stEl=el('st-'+sid);if(stEl){stEl.className='sync-st done';stEl.textContent=`✓ ${data.playerCount}`;}
    }catch{}
    await new Promise(r=>setTimeout(r,400));
  }
  render();showToast(`Sync complete: ${total} new players added.`,'success');
}
function mergeSquad(clubName,data){
  const ci=CLUB_REGISTRY[clubName]||{};
  const step=String(ci.step||data.step||'');
  let added=0;
  for(const p of (data.players||[])){
    if(!p.name)continue;
    const exists=players.find(x=>x.name.toLowerCase()===p.name.toLowerCase()&&(x.currentClub||'').toLowerCase()===clubName.toLowerCase());
    if(exists){if(p.age&&!exists.age)exists.age=p.age;continue;}
    players.push({id:uid(),name:p.name,age:p.age||null,position:p.position||'?',
      currentClub:clubName,step,status:'Not Watched',scoutRating:'',action:'',
      ratingInPoss:0,ratingOutPoss:0,notes:'',
      date:new Date().toISOString().split('T')[0],syncedFromTM:true});
    added++;
  }
  save();return added;
}
function showToast(msg,type=''){
  const t=el('toast');t.textContent=msg;t.className='toast'+(type?' '+type:'');
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3200);
}
document.querySelectorAll('.mo').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));
load();render();
checkServer();setInterval(checkServer,12000);
